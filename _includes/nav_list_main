<!--전체 글 수를 세기 위한 연산. sum 변수에 전체 글 수 저장-->

{% assign sum = site.posts | size %}

<nav class="nav__list">
  <input id="ac-toc" name="accordion-toc" type="checkbox" />
  <label for="ac-toc">{{ site.data.ui-text[site.locale].menu_label }}</label>
  <ul class="nav__items" id="category_tag_menu">
    <!--전체 글 수-->
    <li>
      📂 <span style="font-size: 12px ;">전체 글 수 <span style="color: #0d3b69"><b>{{sum}}</b></span>  개</span>

    </li>
    <li>
      <!--span 태그로 카테고리들을 크게 분류 ex) C/C++/C#-->
      <span class="nav__sub-title">Java</span>
      <!--ul 태그로 같은 카테고리들 모아둔 페이지들 나열-->
      <ul>
        <!--Cpp 카테고리 글들을 모아둔 페이지인 /categories/cpp 주소의 글로 링크 연결-->
        <!--category[1].size 로 해당 카테고리를 가진 글의 개수 표시-->
        {% for category in site.categories %}
        {% if category[0] == "java" %}
        <li><a href="/categories/java" class="">Java ({{category[1].size}})</a></li>
        {% endif %}
        {% endfor %}
      </ul>
      <ul>
        {% for category in site.categories %}
        {% if category[0] == "javaprac" %}
        <li><a href="/categories/javaprac" class="">Java연습 ({{category[1].size}})</a></li>
        {% endif %}
        {% endfor %}
      </ul>
      <span class="nav__sub-title">Java Script</span>
      <ul>
        {% for category in site.categories %}
        {% if category[0] == "js" %}
        <li><a href="/categories/js" class="">JS ({{category[1].size}})</a></li>
        {% endif %}
        {% endfor %}
      </ul>
      <ul>
        {% for category in site.categories %}
        {% if category[0] == "jsprac" %}
        <li><a href="/categories/jsprac" class="">JS 연습 ({{category[1].size}})</a></li>
        {% endif %}
        {% endfor %}
      </ul>

      <span class="nav__sub-title">DataBase</span>
      <ul>
        {% for category in site.categories %}
        {% if category[0] == "db" %}
        <li><a href="/categories/db" class="">DB ({{category[1].size}})</a></li>
        {% endif %}
        {% endfor %}
      </ul>
      <ul>
        {% for category in site.categories %}
        {% if category[0] == "dbprac" %}
        <li><a href="/categories/dbprac" class="">DB연습 ({{category[1].size}})</a></li>
        {% endif %}
        {% endfor %}
      </ul>
      <ul>
        {% for category in site.categories %}
        {% if category[0] == "sqrd" %}
        <li><a href="/categories/sqrd" class="">SQRD ({{category[1].size}})</a></li>
        {% endif %}
        {% endfor %}
      </ul>

      <span class="nav__sub-title">CleanCode</span>
      <ul>
        {% for category in site.categories %}
        {% if category[0] == "cleancode" %}
        <li><a href="/categories/cleancode" class="">클린코드 ({{category[1].size}})</a></li>
        {% endif %}
        {% endfor %}
      </ul>

      <span class="nav__sub-title">Study</span>
      <ul>
        {% for category in site.categories %}
        {% if category[0] == "cote" %}
        <li><a href="/categories/cote" class="">CodingTest ({{category[1].size}})</a></li>
        {% endif %}
        {% endfor %}
      </ul>
      <ul>
        {% for category in site.categories %}
        {% if category[0] == "study" %}
        <li><a href="/categories/study" class="">study ({{category[1].size}})</a></li>
        {% endif %}
        {% endfor %}
      </ul>
      <ul>
        {% for category in site.categories %}
        {% if category[0] == "osiete" %}
        <li><a href="/categories/osiete" class="">おしえて!gpt先生 ({{category[1].size}})</a></li>
        {% endif %}
        {% endfor %}
      </ul>

    </li>
  </ul>
</nav>